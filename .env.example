# --- LOCAL LLM CONFIGURATION (Qwen) ---
# If running Qwen proxy on your machine, use: http://host.docker.internal:8080/v1
LLM_API_KEY=my-secret-qwen-key
LLM_API_BASE=http://host.docker.internal:8080/v1
LLM_MODEL=coder-model

# --- DATABASE CONFIGURATION ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=lms
DATABASE_URL=postgresql://user:password@db:5432/lms
